# Multimodal LLM (OpenAI-compatible) used to auto-fill labels from a vial photo.
#
# By default the app calls the same-origin "/v1" path, which the Vite dev and
# preview servers proxy to the endpoint set in vite.config.ts (LLM_TARGET).
# This keeps requests same-origin and avoids browser CORS.
#
# Override the base URL to call an endpoint directly (the server must send CORS
# headers, e.g. Access-Control-Allow-Origin):
# VITE_LLM_BASE_URL=http://rastalinuxai.local:8080/v1

# Model id sent to the endpoint. This MUST be a real id served by the endpoint
# (see `GET /v1/models`) — llama-swap returns 404 "no router" for unknown ids.
# For photo auto-fill it must be a VISION-capable model (one with an mmproj);
# text-only models return 500 "image input is not supported".
VITE_LLM_MODEL=gemma-4-31b
